---
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand">SW</a>
    <button
      class="site-header__menu-toggle"
      aria-label="Otevřít menu"
      aria-expanded="false"
      aria-controls="site-header-nav"
    >
      Menu
    </button>
    <nav class="site-header__nav" id="site-header-nav">
      <a href="/#hero">Úvodní stránka</a>
      <a href="/#co-nabizim">Co nabízím</a>
      <a href="/#o-mne">O mně</a>
      <a href="/#reference">Reference</a>
      <a href="/blog">Blog</a>
      <a href="/#kontakt">Kontakt</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    padding: 1.25rem 0;
    background: var(--color-accent);
    color: var(--color-accent-contrast);
  }

  .site-header__inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .site-header__brand {
    font-family: var(--font-display);
    font-size: 1.25rem;
    text-decoration: none;
    font-weight: 600;
  }

  .site-header__menu-toggle {
    cursor: pointer;
    padding: 0.5em 1.1em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .site-header__nav {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    z-index: 20;
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 12rem;
    padding: 0.75rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    font-size: 0.95rem;
  }

  .site-header__nav.is-open {
    display: flex;
  }

  .site-header__nav a:not(.button) {
    padding: 0.35rem 0;
    text-decoration: none;
    color: var(--color-text-muted);
  }

  .site-header__nav a:not(.button):hover {
    color: var(--color-text);
  }

  .button--small {
    padding: 0.5em 1.1em;
    font-size: 0.9rem;
  }

  @media (min-width: 769px) {
    .site-header__menu-toggle {
      display: none;
    }

    .site-header__nav {
      display: flex;
      position: static;
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
      min-width: 0;
      padding: 0;
      background: none;
      border: none;
      box-shadow: none;
    }

    .site-header__nav a:not(.button) {
      padding: 0;
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--color-accent-contrast);
    }

    .site-header__nav a:not(.button):hover {
      opacity: 0.8;
      color: var(--color-accent-contrast);
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".site-header__menu-toggle");
  const nav = document.querySelector<HTMLElement>(".site-header__nav");

  toggle?.addEventListener("click", () => {
    const isOpen = nav?.classList.toggle("is-open");
    toggle.setAttribute("aria-expanded", String(Boolean(isOpen)));
  });

  nav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      nav.classList.remove("is-open");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>
