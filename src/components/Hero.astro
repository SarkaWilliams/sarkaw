---
import { getHomeContent } from "../lib/content";
import { normalizeLocale } from "../lib/i18n";

interface Props {
  ctaHref: string;
}

const { ctaHref } = Astro.props;
const home = getHomeContent(normalizeLocale(Astro.currentLocale));
---

<section class="hero" id="hero">
  <div class="container hero__inner">
    <h1>{home.heroTitle}</h1>
    <p class="hero__subtitle">{home.heroSubtitle}</p>
    {home.heroQuote && <p class="hero__quote">{home.heroQuote}</p>}
    <a class="button" href={ctaHref}>{home.ctaText}</a>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(4rem, 10vw, 8rem);
    padding-bottom: clamp(3rem, 8vw, 6rem);
  }

  .hero__inner {
    max-width: 40rem;
    display: flex;
    flex-direction: column;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
  }

  .hero__subtitle {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    margin: 0 0 2rem;
  }

  .hero__quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    margin: 0 0 2rem;
  }
</style>
