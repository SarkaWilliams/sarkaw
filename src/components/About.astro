---
import { getHomeContent } from "../lib/content";
import { normalizeLocale, ui } from "../lib/i18n";

const locale = normalizeLocale(Astro.currentLocale);
const home = getHomeContent(locale);
const t = ui[locale];

// `about` je psáno jako markdown (widget: markdown ve Sveltia).
// Zatím render jako prostý text s odstavci; při potřebě lze napojit markdown parser.
const paragraphs = home.about.split(/\n\s*\n/).filter(Boolean);
---

<section class="about" id="o-mne">
  <div class="container about__inner">
    <img class="about__photo" src={home.aboutImage} alt={t.sections.aboutPhotoAlt} />
    <div class="about__content">
      <h2>{t.sections.aboutHeading}</h2>
      {paragraphs.map((p) => <p>{p}</p>)}
      {home.aboutCredentials.length > 0 && (
        <>
          <p class="about__credentials-heading">{t.sections.credentialsHeading}</p>
          <ul class="about__credentials">
            {home.aboutCredentials.map((item) => <li>{item}</li>)}
          </ul>
        </>
      )}
    </div>
  </div>
</section>

<style>
  .about__inner {
    max-width: 56rem;
    display: grid;
    grid-template-columns: minmax(0, 16rem) 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .about__photo {
    width: 100%;
    border-radius: var(--radius);
  }

  .about p {
    color: var(--color-text-muted);
  }

  .about__credentials-heading {
    font-weight: 600;
    color: var(--color-text);
    margin: 1.5rem 0 0.5rem;
  }

  .about__credentials {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--color-text-muted);
  }

  .about__credentials li {
    margin-bottom: 0.4rem;
  }

  @media (max-width: 640px) {
    .about__inner {
      grid-template-columns: 1fr;
    }

    .about__photo {
      max-width: 14rem;
      margin: 0 auto;
    }
  }
</style>
