---
import { home } from "../lib/content";

// `about` je psáno jako markdown (widget: markdown ve Sveltia).
// Zatím render jako prostý text s odstavci; při potřebě lze napojit markdown parser.
const paragraphs = home.about.split(/\n\s*\n/).filter(Boolean);
---

<section class="about" id="o-mne">
  <div class="container about__inner">
    <img class="about__photo" src={home.aboutImage} alt="Šárka Williams" />
    <div class="about__content">
      <h2>O mně</h2>
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </div>
</section>

<style>
  .about__inner {
    max-width: 56rem;
    display: grid;
    grid-template-columns: minmax(0, 16rem) 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .about__photo {
    width: 100%;
    border-radius: var(--radius);
  }

  .about p {
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .about__inner {
      grid-template-columns: 1fr;
    }

    .about__photo {
      max-width: 14rem;
      margin: 0 auto;
    }
  }
</style>
