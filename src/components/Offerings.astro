---
import { home } from "../lib/content";

const offerings = home.offerings.map((offering) => ({
  ...offering,
  introParagraphs: offering.intro.split(/\n\s*\n/).filter(Boolean),
}));
---

<section class="offerings" id="co-nabizim">
  <div class="container">
    <h2>Co nabízím</h2>
    <div class="offerings__list">
      {offerings.map((offering) => (
        <details class="offering">
          <summary>{offering.title}</summary>
          <div class="offering__content">
            {offering.quote && <p class="offering__quote">{offering.quote}</p>}
            {offering.introParagraphs.map((p) => <p>{p}</p>)}
            {offering.itemsHeading && <p class="offering__items-heading">{offering.itemsHeading}</p>}
            <ul>
              {offering.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <div class="offering__pricing">
              <p class="offering__pricing-note">
                Konečná cena se stanovuje individuálně podle rozsahu spolupráce.
              </p>
              <ul class="offering__pricing-list">
                {offering.pricing.map((item) => (
                  <li>
                    <span>{item.label}</span>
                    <span>{item.price}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .offerings__list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .offering {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    background: color-mix(in srgb, var(--color-bg) 55%, transparent);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
  }

  .offering summary {
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
  }

  .offering[open] summary {
    margin-bottom: 1rem;
  }

  .offering__content p {
    color: var(--color-text-muted);
    margin: 0 0 1rem;
  }

  .offering__quote {
    font-family: var(--font-display);
    font-style: italic;
  }

  .offering__content p.offering__items-heading {
    font-weight: 600;
    color: var(--color-text);
  }

  .offering__content ul {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--color-text-muted);
  }

  .offering__content li {
    margin-bottom: 0.4rem;
  }

  .offering__pricing {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .offering__pricing-note {
    font-style: italic;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
  }

  .offering__pricing-list {
    list-style: none;
    margin: 0;
    padding: 0;
    color: var(--color-text-muted);
  }

  .offering__pricing-list li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }

  .offering__pricing-list li span:last-child {
    font-weight: 600;
    white-space: nowrap;
  }
</style>
