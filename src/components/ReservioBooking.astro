---
import { home } from "../lib/content";
---

<!--
  Reservio napojení (viz PROJEKT-BRIEF.md, sekce "Reservio — napojení").

  Aktuálně: jednoduché tlačítko odkazující na Reservio (ctaUrl v home.json,
  klientka si ho může sama upravit ve Sveltia CMS).

  Až padne rozhodnutí "odkaz vs. embed", stačí tuto sekci nahradit iframem
  z Reservio dashboardu, např.:

  <iframe
    src="https://booking.reservio.com/PLACEHOLDER"
    style="width:100%; min-height:640px; border:0;"
    loading="lazy"
    title="Rezervační kalendář"
  ></iframe>
-->
<section class="booking section-alt" id="rezervace">
  <div class="container booking__inner">
    <h2>Rezervace</h2>
    <p>Vyber si termín, který ti vyhovuje. Rezervaci i připomínky řeší Reservio.</p>
    <a class="button" href={home.ctaUrl} target="_blank" rel="noopener noreferrer">
      {home.ctaText}
    </a>
  </div>
</section>

<style>
  .booking__inner {
    max-width: 36rem;
    text-align: center;
  }

  .booking p {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
</style>
