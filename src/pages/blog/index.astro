---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (date: Date) =>
  date.toLocaleDateString("cs-CZ", { day: "numeric", month: "long", year: "numeric" });
---

<Layout title="Blog | Koučink" description="Články o osobním růstu a manažerské praxi.">
  <section class="blog" id="blog">
    <div class="container">
      <h1>Blog</h1>
      <p class="blog__intro">Články o osobním růstu, koučinku a manažerské praxi.</p>
      <div class="blog__list">
        {posts.map((post) => (
          <article class="blog-card">
            <p class="blog-card__date">{formatDate(post.data.date)}</p>
            <h2 class="blog-card__title">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h2>
            <p class="blog-card__excerpt">{post.data.excerpt}</p>
            <a class="blog-card__link" href={`/blog/${post.id}`}>Číst dál →</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .blog__intro {
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  .blog__list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .blog-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    background: color-mix(in srgb, var(--color-bg) 55%, transparent);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
  }

  .blog-card__date {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin: 0 0 0.4rem;
  }

  .blog-card__title {
    margin: 0 0 0.6rem;
    font-size: 1.15rem;
  }

  .blog-card__title a {
    text-decoration: none;
  }

  .blog-card__title a:hover {
    text-decoration: underline;
  }

  .blog-card__excerpt {
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .blog-card__link {
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .blog-card__link:hover {
    text-decoration: underline;
  }
</style>
